@page "/konto/logowanie"
@model FryzjerBooking.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Logowanie";
}

<div class="auth-page">
    <form method="post" class="auth-card">
        <p class="eyebrow">Konto klienta</p>
        <h1>Logowanie</h1>
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <label>
            E-mail
            <input asp-for="Input.Email" autocomplete="email" />
            <span asp-validation-for="Input.Email"></span>
        </label>

        <label>
            Hasło
            <input asp-for="Input.Haslo" autocomplete="current-password" />
            <span asp-validation-for="Input.Haslo"></span>
        </label>

        <label class="checkbox-label">
            <input asp-for="Input.ZapamietajMnie" />
            Zapamiętaj mnie
        </label>

        <button class="button primary wide" type="submit">Zaloguj</button>
        <a href="/konto/rejestracja">Załóż nowe konto</a>
    </form>
</div>
