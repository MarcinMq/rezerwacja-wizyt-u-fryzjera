@using Microsoft.AspNetCore.Identity
@using FryzjerBooking.Models
@inject SignInManager<UzytkownikAplikacji> SignInManager

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Fryzjer Booking</title>
    <base href="/" />
    <link rel="stylesheet" href="css/app.css" />
</head>
<body>
    <div class="page-shell">
        <header class="topbar">
            <a class="brand" href="/">
                <span class="brand-mark">BB</span>
                <span>Fryzjer Booking</span>
            </a>

            <nav class="nav-links">
                <a href="/">Usługi</a>
                @if (SignInManager.IsSignedIn(User))
                {
                    <a href="/rezerwacja">Rezerwuj</a>
                    <a href="/moje-wizyty">Moje wizyty</a>
                }
            </nav>

            <div class="account-actions">
                @if (SignInManager.IsSignedIn(User))
                {
                    <form method="post" action="/konto/wyloguj">
                        <button class="button subtle" type="submit">Wyloguj</button>
                    </form>
                }
                else
                {
                    <a class="button subtle" href="/konto/logowanie">Logowanie</a>
                    <a class="button primary" href="/konto/rejestracja">Rejestracja</a>
                }
            </div>
        </header>

        <main class="content">
            @RenderBody()
        </main>
    </div>
</body>
</html>
